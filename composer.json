{
    "name": "lphenom/queue",
    "description": "LPhenom queue package — DB and Redis queue drivers with retry policy, KPHP-compatible",
    "type": "library",
    "license": "MIT",
    "keywords": ["queue", "lphenom", "kphp", "jobs", "retry"],
    "homepage": "https://github.com/lphenom/queue",
    "authors": [
        {
            "name": "dmitrii-pov",
            "email": "popkovd.o@yandex.ru"
        }
    ],
    "require": {
        "php": ">=8.1",
        "lphenom/db": "^0.1",
        "lphenom/redis": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.40 <3.65"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/lphenom/db"
        },
        {
            "type": "vcs",
            "url": "https://github.com/lphenom/redis"
        }
    ],
    "autoload": {
        "psr-4": {
            "LPhenom\\Queue\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LPhenom\\Queue\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --colors=always",
        "lint": "vendor/bin/php-cs-fixer fix --dry-run --diff --allow-risky=yes",
        "lint-fix": "vendor/bin/php-cs-fixer fix --allow-risky=yes",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=256M",
        "check": ["@lint", "@analyse", "@test"]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.1.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

